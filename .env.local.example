# Supabase (읽기 — 클라이언트 번들에 포함됨)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# 서버 전용 — 절대 NEXT_PUBLIC_ 접두사 금지, 클라이언트에 노출 금지
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# 편집 모드 공유 PIN (Phase 2부터 사용)
EDIT_PIN=changeme

# 편집 세션 쿠키 서명 키 (32바이트 이상 랜덤). 예: openssl rand -hex 32
EDIT_SESSION_SECRET=replace-with-32+-byte-random-secret
